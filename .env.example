# ======================
# Supabase Configuration
# ======================
# Your Supabase project URL — found in Project Settings > API
co

# Your Supabase anon/public key — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Your Supabase service role key (used server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ======================
# Backend Configuration
# ======================
# Port the Express server will listen on
BACKEND_PORT=4000

# Node environment: development | production | test
NODE_ENV=development

# ======================
# Frontend Configuration
# ======================
# Full URL of your backend API (used by Next.js to call Express)
NEXT_PUBLIC_API_URL=http://localhost:4000
